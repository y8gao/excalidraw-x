{
  "name": "excalidraw-x",
  "version": "0.1.1",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron-forge start",
    "dev": "concurrently \"webpack serve\" \"electron . --remote-debugging-port=9222\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "webpack --mode production",
    "prod": "electron .",
    "package": "npm run build && electron-forge package",
    "make": "npm run build && electron-forge make",
    "make:win": "npm run build && electron-forge make --platform win32 --arch x64"
  },
  "keywords": [],
  "author": "Yang Gao <yang.xz.gao@outlook.com>",
  "license": "MIT",
  "description": "excalidraw desktop client.",
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "d3": "^7.9.0",
    "electron-is-dev": "^2.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "babel-jest": "^30.3.0",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.8.1",
    "electron": "^40.8.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "html-webpack-plugin": "^5.5.3",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "style-loader": "^3.3.3",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.3"
  }
}
